# YURA configuration. Copy to .env and adjust.
# API keys can also be set in the in-app Settings page (stored in SQLite).
YURA_HOST=127.0.0.1
YURA_PORT=8000
YURA_DATA_DIR=./data
YURA_WORKSPACE_DIR=./workspace
# Optional: seed keys here instead of via the Settings UI
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
